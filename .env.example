# ============================================================
# SmartPrint Station (Print Kiosk) — Environment Configuration
# ============================================================
# Replace these dummy values with your actual system parameters.
# DO NOT commit real API keys or secrets to version control.

# --- Server Configuration ---
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=development
LOCAL_PROD=0

# --- Razorpay Payment Gateway (Test / Live Keys) ---
RAZORPAY_KEY_ID=rzp_test_your_dummy_key_id_here
RAZORPAY_KEY_SECRET=your_dummy_razorpay_key_secret_here

# --- Hardware Integration & Drivers ---
# IP Address or Hostname of your eSCL-compatible network scanner (e.g. HP WorkForce / OfficeJet)
PRINTER_IP=192.168.1.100

# Explicit CUPS Printer Name (as shown in `lpstat -p`)
PRINTER_NAME=HP_LaserJet_Pro_MFP_M28w

# Explicit USB UART Port for ESP32 Kiosk Display & MPU-6050
SERIAL_PORT=/dev/cu.usbserial-0001
ESP32_BAUDRATE=115200

# --- Security & Sessions ---
SESSION_SECRET=your_super_secret_session_encryption_key_here
DATABASE_URL=file:./kiosk.db
